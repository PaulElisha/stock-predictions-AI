{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@app/*": [
                "./src/app/*"
            ],
            "@config/*": [
                "./src/config/*"
            ],
            "@module/*": [
                "./src/module/*"
            ],
            "@type/*": [
                "./src/type/*"
            ],
            "@util/*": [
                "src/shared/util/*"
            ],
            "@enum/*": [
                "src/shared/enum/*"
            ],
            "@error/*": [
                "src/shared/error/*"
            ],
            "@middleware/*": [
                "src/shared/middleware/*"
            ]
        },
        "noEmit": true,
        "emitDecoratorMetadata": true,
        "emitDeclarationOnly": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "moduleResolution": "node",
        "module": "ES2022",
        "target": "ES2022",
        "strict": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "allowSyntheticDefaultImports": true,
        "useUnknownInCatchVariables": true,
        "allowJs": true
    },
    "include": [
        "src/**/*.ts",
        "app.ts",
        "declarations.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
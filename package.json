{
  "name": "stock-predictions-ai",
  "version": "1.0.0",
  "main": "dist/app.js",
  "type": "module",
  "repository": "https://github.com/PaulElisha/stock-predictions-ai.git",
  "author": "Paul Elisha <ireajao@yahoo.com>",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/app.ts --bundle --platform=node --target=node18 --format=esm --packages=external --outfile=dist/app.js",
    "dev": "tsx watch src/app.ts",
    "clean": "rm -rf dist",
    "clear-cache": "rm -rf node_modules/.cache",
    "install-legacy": "npm install --legacy-peer-deps",
    "git-refresh-case": "git rm --cached -r . || true && git add -A && git commit -m \"chore: refresh case-sensitive filenames\" || true",
    "git-clear-case": "git rm --cached constants/Constants.js 2>/dev/null || true && git add constants/Constants.js"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/axios": "^0.9.36",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/mongodb": "^4.0.6",
    "@types/mongoose": "^5.11.96",
    "dotenv": "^17.2.3",
    "nodemon": "^3.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.10.0",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "fasy": "^9.0.2",
    "mongodb": "^6.21.0",
    "mongoose": "^8.19.3"
  }
}
